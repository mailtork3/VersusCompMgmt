# Angular / Node.js
# ============================================================

# Dependencies
frontend/node_modules/

# Build output
frontend/dist/
frontend/.angular/

# Environment files — keep .example files, ignore actual values
frontend/src/environments/environment.local.ts
*.env
.env
.env.*
!.env.example

# Test cache
frontend/coverage/
frontend/.nyc_output/

# Vitest cache
frontend/.vitest/

# ============================================================
